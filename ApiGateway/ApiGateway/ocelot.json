{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/jobs",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "jobservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/jobs",
      "UpstreamHttpMethod": [ "GET", "POST" ]
    },
    {
      "DownstreamPathTemplate": "/api/jobs/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "jobservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/jobs/{id}",
      "UpstreamHttpMethod": [ "GET", "PUT", "DELETE" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://apigateway:8080"
  }
}